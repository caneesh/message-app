# Firebase Admin SDK Configuration
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Chat Configuration
# Generate a unique ID for your private chat (e.g., UUID or descriptive name)
PRIVATE_CHAT_ID=private-chat-001

# User IDs for the two chat members
# Get these from Firebase Console > Authentication > Users
USER_ID_1=uid_of_first_user
USER_ID_2=uid_of_second_user
