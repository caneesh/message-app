# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Private Chat ID (created by admin script)
VITE_PRIVATE_CHAT_ID=your_private_chat_id

# Test Login (dev/staging only - DO NOT ENABLE IN PRODUCTION)
# Hidden login flow: 400 page → tap "400" 3x → tap top-left → 500 page → double-tap zones
# VITE_ENABLE_TEST_LOGIN=true
# VITE_TEST_PHONE_HCSC=+11231231234
# VITE_TEST_PHONE_HCL=+11231231235
# VITE_TEST_CODE=123456
# VITE_TEST_LOGIN_ALLOWED_HOSTS=localhost,127.0.0.1

# Simple Mode - show only Messages and Settings (hide other sections temporarily)
# VITE_SIMPLE_MODE=true

# WebRTC Configuration for Video Calling
# STUN servers (comma-separated, default: Google's public STUN servers)
# VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server (optional, but recommended for reliable mobile connectivity)
# VITE_WEBRTC_TURN_URL=turn:your-turn-server.com:443
# VITE_WEBRTC_TURN_USERNAME=your_username
# VITE_WEBRTC_TURN_CREDENTIAL=your_credential
