rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is a member of the chat
    function isChatMember(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    // Helper: Validate message has only allowed fields
    function hasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly(['senderId', 'senderPhone', 'type', 'text', 'createdAt', 'replyTo', 'file', 'voice', 'edited', 'editedAt', 'specialType', 'title', 'style', 'unlockAt', 'expiresAt', 'isLocked', 'requiresReveal', 'expiresOnView', 'thoughtRef', 'transcriptionStatus', 'transcriptText', 'transcriptCreatedAt', 'transcriptUpdatedAt', 'transcriptRequestedBy', 'transcriptErrorCode', 'messageIntent', 'attachmentCount', 'firstPreviewStoragePath', 'status', 'updatedAt', 'revealTitle', 'revealPrompt', 'hiddenContent', 'revealKind']);
    }

    // Helper: Validate optional messageIntent field (priority labels)
    function isValidMessageIntent() {
      let data = request.resource.data;
      return !('messageIntent' in data) || data.messageIntent in ['normal', 'important', 'need_reply', 'urgent', 'just_sharing', 'sensitive', 'love'];
    }

    // Helper: Validate optional thoughtRef field
    function isValidThoughtRef() {
      let data = request.resource.data;
      return !('thoughtRef' in data) || (
        data.thoughtRef is map
        && data.thoughtRef.keys().hasOnly(['thoughtId', 'blockId', 'quote', 'authorId'])
        && data.thoughtRef.thoughtId is string
        && (!('blockId' in data.thoughtRef) || data.thoughtRef.blockId is string)
        && data.thoughtRef.quote is string
        && data.thoughtRef.quote.size() <= 300
        && data.thoughtRef.authorId is string
      );
    }

    // Helper: Validate message edit (only text/edited/editedAt can change)
    function isValidMessageEdit() {
      let existing = resource.data;
      let incoming = request.resource.data;
      return existing.senderId == request.auth.uid
          && existing.type == 'text'
          && incoming.senderId == existing.senderId
          && incoming.senderPhone == existing.senderPhone
          && incoming.type == existing.type
          && incoming.createdAt == existing.createdAt
          && (!('replyTo' in existing) || incoming.replyTo == existing.replyTo)
          && (!('file' in existing) || incoming.file == existing.file)
          && incoming.text is string
          && incoming.text.size() > 0
          && incoming.text.size() <= 2000
          && incoming.edited == true
          && 'editedAt' in incoming;
    }

    // Helper: Validate transcription request (chat member can request or mark failed)
    function isValidTranscriptionRequest() {
      let existing = resource.data;
      let incoming = request.resource.data;
      let changedKeys = incoming.diff(existing).affectedKeys();
      // Allow setting to pending (new request) or failed (error recovery)
      return existing.type == 'voice'
          && changedKeys.hasOnly(['transcriptionStatus', 'transcriptRequestedBy', 'transcriptUpdatedAt', 'transcriptErrorCode'])
          && incoming.transcriptionStatus in ['pending', 'failed'];
    }

    // Helper: Validate base message fields
    function isValidBaseMessage() {
      let data = request.resource.data;
      return data.senderId == request.auth.uid
          && data.type in ['text', 'file', 'video', 'voice', 'special', 'attachment_bundle', 'reveal']
          && (data.type == 'reveal' || (data.text is string && data.text.size() <= 5000));
    }

    // Helper: Validate attachment bundle message
    function isValidAttachmentBundleMessage() {
      let data = request.resource.data;
      return data.type == 'attachment_bundle'
          && data.attachmentCount is number
          && data.attachmentCount >= 1
          && data.attachmentCount <= 10
          && data.status in ['uploading', 'sent', 'failed']
          && (!('firstPreviewStoragePath' in data) || data.firstPreviewStoragePath == null || data.firstPreviewStoragePath is string);
    }

    // Helper: Validate attachment bundle status update
    function isValidAttachmentBundleUpdate() {
      let existing = resource.data;
      let incoming = request.resource.data;
      return existing.type == 'attachment_bundle'
          && existing.senderId == request.auth.uid
          && incoming.senderId == existing.senderId
          && incoming.senderPhone == existing.senderPhone
          && incoming.type == existing.type
          && incoming.attachmentCount == existing.attachmentCount
          && incoming.status in ['uploading', 'sent', 'failed']
          && incoming.diff(existing).affectedKeys().hasOnly(['status', 'firstPreviewStoragePath', 'updatedAt']);
    }

    // Helper: Validate attachment document
    function isValidAttachment() {
      let data = request.resource.data;
      return data.keys().hasOnly(['attachmentId', 'messageId', 'chatId', 'uploadedBy', 'storagePath', 'fileName', 'contentType', 'size', 'kind', 'order', 'createdAt'])
          && data.uploadedBy == request.auth.uid
          && data.storagePath is string
          && data.fileName is string
          && data.contentType is string
          && data.size is number
          && data.size <= 100 * 1024 * 1024
          && data.kind in ['image', 'video', 'audio', 'document']
          && data.order is number
          && data.order >= 0
          && data.order < 10;
    }

    // Helper: Validate special message
    function isValidSpecialMessage() {
      let data = request.resource.data;
      return data.type == 'special'
          && data.specialType in ['letter', 'hold_reveal', 'timed_unlock', 'disappearing']
          && data.text.size() > 0
          && (!('title' in data) || (data.title is string && data.title.size() <= 120))
          && (!('style' in data) || data.style in ['letter', 'love', 'soft'])
          && (!('unlockAt' in data) || data.unlockAt is timestamp)
          && (!('expiresAt' in data) || data.expiresAt is timestamp)
          && (!('isLocked' in data) || data.isLocked is bool)
          && (!('requiresReveal' in data) || data.requiresReveal is bool)
          && (!('expiresOnView' in data) || data.expiresOnView is bool);
    }

    // Helper: Validate reveal message (hidden answer/content)
    function isValidRevealMessage() {
      let data = request.resource.data;
      return data.type == 'reveal'
          && data.revealPrompt is string
          && data.revealPrompt.size() > 0
          && data.revealPrompt.size() <= 1000
          && data.hiddenContent is string
          && data.hiddenContent.size() > 0
          && data.hiddenContent.size() <= 3000
          && (!('revealTitle' in data) || (data.revealTitle is string && data.revealTitle.size() <= 120))
          && (!('revealKind' in data) || data.revealKind in ['puzzle', 'surprise', 'spoiler', 'secret', 'question']);
    }

    // Helper: Validate text message
    function isValidTextMessage() {
      let data = request.resource.data;
      return data.type == 'text' && data.text.size() > 0;
    }

    // Helper: Validate file message (images/documents)
    function isValidFileMessage() {
      let data = request.resource.data;
      return data.type == 'file'
          && 'file' in data
          && data.file is map
          && data.file.keys().hasOnly(['storagePath', 'fileName', 'contentType', 'size', 'url'])
          && data.file.storagePath is string
          && data.file.fileName is string
          && data.file.contentType is string
          && data.file.size is number
          && data.file.size <= 25 * 1024 * 1024;
    }

    // Helper: Validate video message
    function isValidVideoMessage() {
      let data = request.resource.data;
      return data.type == 'video'
          && 'file' in data
          && data.file is map
          && data.file.keys().hasOnly(['storagePath', 'fileName', 'contentType', 'size', 'url'])
          && data.file.storagePath is string
          && data.file.fileName is string
          && data.file.contentType is string
          && data.file.size is number
          && data.file.size <= 100 * 1024 * 1024;
    }

    // Helper: Validate voice message
    function isValidVoiceMessage() {
      let data = request.resource.data;
      return data.type == 'voice'
          && data.text == ''
          && 'voice' in data
          && data.voice is map
          && data.voice.keys().hasOnly(['storagePath', 'contentType', 'size', 'durationSeconds', 'url'])
          && data.voice.storagePath is string
          && data.voice.contentType is string
          && data.voice.contentType in ['audio/webm;codecs=opus', 'audio/webm', 'audio/mp4', 'audio/mpeg', 'audio/aac']
          && data.voice.size is number
          && data.voice.size <= 5 * 1024 * 1024
          && data.voice.durationSeconds is number
          && data.voice.durationSeconds <= 60;
    }

    // Helper: Validate optional replyTo field
    function isValidReplyTo() {
      let data = request.resource.data;
      return !('replyTo' in data) || (
        data.replyTo is map
        && data.replyTo.keys().hasOnly(['messageId', 'senderId', 'textPreview', 'fileInfo'])
        && data.replyTo.messageId is string
        && data.replyTo.senderId is string
        && data.replyTo.textPreview is string
        && data.replyTo.textPreview.size() <= 120
      );
    }

    // Helper: Validate lastReadAt update (only own uid field)
    function isValidLastReadAtUpdate() {
      let existing = resource.data;
      let incoming = request.resource.data;
      let onlyLastReadAtChanged = incoming.members == existing.members
          && incoming.diff(existing).affectedKeys().hasOnly(['lastReadAt']);
      let validLastReadAtChange = !('lastReadAt' in existing)
          || incoming.lastReadAt.diff(existing.lastReadAt).affectedKeys().hasOnly([request.auth.uid]);
      return onlyLastReadAtChanged && validLastReadAtChange;
    }

    // Helper: Validate autoDelete update
    function isValidAutoDeleteUpdate() {
      let existing = resource.data;
      let incoming = request.resource.data;
      return incoming.members == existing.members
          && incoming.diff(existing).affectedKeys().hasOnly(['autoDelete'])
          && incoming.autoDelete.keys().hasOnly(['enabled', 'durationDays'])
          && incoming.autoDelete.enabled is bool
          && incoming.autoDelete.durationDays in [1, 7, 30];
    }

    // Chat documents - read only for members, limited update for lastReadAt and autoDelete
    match /chats/{chatId} {
      allow read: if isAuthenticated() && isChatMember(chatId);
      allow update: if isAuthenticated()
                    && isChatMember(chatId)
                    && (isValidLastReadAtUpdate() || isValidAutoDeleteUpdate());
      allow create, delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && hasOnlyAllowedFields()
                      && isValidBaseMessage()
                      && (isValidTextMessage() || isValidFileMessage() || isValidVideoMessage() || isValidVoiceMessage() || isValidSpecialMessage() || isValidRevealMessage() || isValidAttachmentBundleMessage())
                      && isValidReplyTo()
                      && isValidThoughtRef()
                      && isValidMessageIntent();
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && (isValidMessageEdit() || isValidTranscriptionRequest() || isValidAttachmentBundleUpdate());
        allow delete: if isAuthenticated()
                      && isChatMember(chatId);

        // Attachments subcollection for attachment bundles
        match /attachments/{attachmentId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && isValidAttachment();
          allow update, delete: if false;
        }

        // Reactions subcollection - doc ID must equal user's uid
        match /reactions/{reactionId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create, update: if isAuthenticated()
                                && isChatMember(chatId)
                                && reactionId == request.auth.uid
                                && request.resource.data.keys().hasOnly(['uid', 'emoji', 'createdAt'])
                                && request.resource.data.uid == request.auth.uid
                                && request.resource.data.emoji in ['👍', '❤️', '❤️‍🔥', '😂', '😮', '😢', '🙏', '🤗', '✨']
                                && request.resource.data.emoji is string;
          allow delete: if isAuthenticated()
                        && isChatMember(chatId)
                        && reactionId == request.auth.uid;
        }

        // Emotional receipts subcollection - doc ID must equal user's uid
        match /emotionalReceipts/{receiptId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create, update: if isAuthenticated()
                                && isChatMember(chatId)
                                && receiptId == request.auth.uid
                                && request.resource.data.keys().hasOnly(['uid', 'receipt', 'createdAt', 'updatedAt'])
                                && request.resource.data.uid == request.auth.uid
                                && request.resource.data.receipt in ['understood', 'need_time', 'disagree', 'feel_hurt', 'appreciate', 'talk_later'];
          allow delete: if isAuthenticated()
                        && isChatMember(chatId)
                        && receiptId == request.auth.uid;
        }

        // Edit history subcollection
        match /editHistory/{versionId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['versionId', 'previousText', 'editedBy', 'editedAt', 'createdAt'])
                        && request.resource.data.editedBy == request.auth.uid
                        && request.resource.data.previousText is string
                        && request.resource.data.previousText.size() <= 5000;
          allow update, delete: if false;
        }

        // Message removal requests (for "This hurt me" feature)
        match /removalRequests/{requestId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['requestId', 'chatId', 'messageId', 'requestedBy', 'requestedAt', 'feeling', 'note', 'status', 'resolvedBy', 'resolvedAt', 'resolution'])
                        && request.resource.data.requestedBy == request.auth.uid
                        && request.resource.data.status == 'pending'
                        && request.resource.data.feeling in ['hurt', 'upset', 'angry', 'overwhelmed', 'need_space', 'prefer_not_to_say']
                        && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 300));
          allow update: if isAuthenticated()
                        && isChatMember(chatId)
                        && resource.data.requestedBy != request.auth.uid
                        && request.resource.data.status in ['accepted', 'dismissed']
                        && request.resource.data.resolvedBy == request.auth.uid;
          allow delete: if isAuthenticated()
                        && isChatMember(chatId)
                        && resource.data.requestedBy == request.auth.uid
                        && resource.data.status == 'pending';
        }
      }

      // Per-user message state (saved messages)
      match /messageUserState/{uid}/saved/{messageId} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && request.resource.data.keys().hasOnly(['messageId', 'userId', 'saved', 'createdAt', 'updatedAt'])
                              && request.resource.data.userId == request.auth.uid
                              && request.resource.data.saved == true;
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Per-user message archive state (read archive / hidden messages)
      match /messageUserState/{uid}/items/{messageId} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && request.resource.data.keys().hasOnly(['messageId', 'hiddenFromMainView', 'hiddenFromArchiveView', 'hiddenReason', 'hiddenAt', 'archiveClearedAt', 'archiveClearBatchId', 'updatedAt'])
                              && request.resource.data.hiddenReason in ['read', 'clear_all', 'delete_for_me', 'manual_archive'];
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Message reminders (Reply Later feature)
      match /messageReminders/{uid}/items/{reminderId} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && request.resource.data.keys().hasOnly(['reminderId', 'messageId', 'userId', 'remindAt', 'status', 'note', 'createdAt', 'updatedAt', 'completedAt'])
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.status == 'active'
                      && request.resource.data.remindAt is timestamp
                      && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 300));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.status in ['active', 'completed', 'cancelled'];
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Message clear state (soft delete per user) - doc ID must equal user's uid
      match /messageClearState/{uid} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && request.resource.data.keys().hasOnly(['clearedAt', 'clearedBy', 'messageCount', 'mediaCount', 'updatedAt', 'clearHistory'])
                              && request.resource.data.clearedBy == request.auth.uid;
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Message reveal state (tracks which reveal messages user has revealed) - doc ID must equal user's uid
      match /messageRevealState/{uid} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && request.resource.data.keys().hasOnly(['userId', 'revealedMessageIds', 'updatedAt'])
                              && request.resource.data.userId == request.auth.uid
                              && request.resource.data.revealedMessageIds is list;
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Typing indicator subcollection - doc ID must equal user's uid
      match /typing/{typingId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && typingId == request.auth.uid
                              && request.resource.data.keys().hasOnly(['uid', 'isTyping', 'updatedAt'])
                              && request.resource.data.uid == request.auth.uid
                              && request.resource.data.isTyping is bool;
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && typingId == request.auth.uid;
      }

      // Pinned messages subcollection
      match /pinnedMessages/{pinnedId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['messageId', 'pinnedBy', 'pinnedAt', 'textPreview', 'senderId', 'type'])
                      && request.resource.data.pinnedBy == request.auth.uid
                      && request.resource.data.messageId is string
                      && request.resource.data.textPreview is string
                      && request.resource.data.senderId is string
                      && request.resource.data.type in ['text', 'file', 'voice'];
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Shared reminders subcollection with accountability
      match /reminders/{reminderId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'notes', 'dueAt', 'completed', 'createdBy', 'createdAt', 'updatedAt', 'assignedTo', 'priority', 'completedBy', 'completedAt', 'sourceMessageId'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
                      && request.resource.data.completed is bool
                      && (!('priority' in request.resource.data) || request.resource.data.priority in ['low', 'normal', 'high'])
                      && (!('assignedTo' in request.resource.data) || request.resource.data.assignedTo in get(/databases/$(database)/documents/chats/$(chatId)).data.members);
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'notes', 'dueAt', 'completed', 'createdBy', 'createdAt', 'updatedAt', 'assignedTo', 'priority', 'completedBy', 'completedAt', 'sourceMessageId'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
                      && request.resource.data.completed is bool
                      && (!('priority' in request.resource.data) || request.resource.data.priority in ['low', 'normal', 'high'])
                      && (!('assignedTo' in request.resource.data) || request.resource.data.assignedTo in get(/databases/$(database)/documents/chats/$(chatId)).data.members)
                      && (!('completedBy' in request.resource.data) || request.resource.data.completedBy == null || request.resource.data.completedBy in get(/databases/$(database)/documents/chats/$(chatId)).data.members);
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Important dates subcollection
      match /importantDates/{dateId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'date', 'notes', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200;
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'date', 'notes', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200;
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Shared lists subcollection
      match /lists/{listId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200;
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200;
        allow delete: if isAuthenticated() && isChatMember(chatId);

        // List items subcollection
        match /items/{itemId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['text', 'completed', 'createdBy', 'createdAt', 'updatedAt'])
                        && request.resource.data.createdBy == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 500
                        && request.resource.data.completed is bool;
          allow update: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['text', 'completed', 'createdBy', 'createdAt', 'updatedAt'])
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 500
                        && request.resource.data.completed is bool;
          allow delete: if isAuthenticated() && isChatMember(chatId);
        }
      }

      // Shared notes subcollection
      match /notes/{noteId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'body', 'createdBy', 'updatedBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.body is string
                      && request.resource.data.body.size() <= 10000;
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'body', 'createdBy', 'updatedBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.updatedBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.body is string
                      && request.resource.data.body.size() <= 10000;
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Calendar events subcollection
      match /events/{eventId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'startAt', 'endAt', 'notes', 'location', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
                      && (!('location' in request.resource.data) || (request.resource.data.location is string && request.resource.data.location.size() <= 200));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'startAt', 'endAt', 'notes', 'location', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
                      && (!('location' in request.resource.data) || (request.resource.data.location is string && request.resource.data.location.size() <= 200));
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Memories subcollection
      match /memories/{memoryId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'date', 'createdBy', 'createdAt', 'updatedAt', 'coverFilePath', 'sourceMessageId'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 5000));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'date', 'createdBy', 'createdAt', 'updatedAt', 'coverFilePath', 'sourceMessageId'])
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 5000));
        allow delete: if isAuthenticated() && isChatMember(chatId);

        // Perspectives subcollection - doc ID must equal user's uid
        match /perspectives/{perspectiveId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create, update: if isAuthenticated()
                                && isChatMember(chatId)
                                && perspectiveId == request.auth.uid
                                && request.resource.data.keys().hasOnly(['uid', 'text', 'createdAt', 'updatedAt'])
                                && request.resource.data.uid == request.auth.uid
                                && request.resource.data.text is string
                                && request.resource.data.text.size() > 0
                                && request.resource.data.text.size() <= 3000;
          allow delete: if isAuthenticated()
                        && isChatMember(chatId)
                        && perspectiveId == request.auth.uid;
        }
      }

      // Daily check-ins subcollection
      match /checkIns/{checkInId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['userId', 'dateKey', 'mood', 'note', 'createdAt', 'updatedAt'])
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.mood in ['😊', '😐', '😟', '😴', '❤️']
                      && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 500));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.mood in ['😊', '😐', '😟', '😴', '❤️']
                      && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 500));
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && resource.data.userId == request.auth.uid;
      }

      // Shared decisions subcollection
      match /decisions/{decisionId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'decision', 'reason', 'status', 'relatedMessageId', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.decision is string
                      && request.resource.data.decision.size() > 0
                      && request.resource.data.decision.size() <= 2000
                      && (!('reason' in request.resource.data) || (request.resource.data.reason is string && request.resource.data.reason.size() <= 2000))
                      && request.resource.data.status in ['active', 'changed', 'cancelled'];
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'decision', 'reason', 'status', 'relatedMessageId', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.updatedBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.decision is string
                      && request.resource.data.decision.size() > 0
                      && request.resource.data.decision.size() <= 2000
                      && (!('reason' in request.resource.data) || (request.resource.data.reason is string && request.resource.data.reason.size() <= 2000))
                      && request.resource.data.status in ['active', 'changed', 'cancelled'];
        allow delete: if isAuthenticated() && isChatMember(chatId);

        // Decision changes history subcollection
        match /changes/{changeId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['oldDecision', 'newDecision', 'reason', 'changedBy', 'changedAt'])
                        && request.resource.data.changedBy == request.auth.uid
                        && request.resource.data.oldDecision is string
                        && request.resource.data.newDecision is string
                        && request.resource.data.oldDecision.size() <= 2000
                        && request.resource.data.newDecision.size() <= 2000
                        && (!('reason' in request.resource.data) || (request.resource.data.reason is string && request.resource.data.reason.size() <= 500));
          allow update, delete: if false;
        }
      }

      // Promises subcollection
      match /promises/{promiseId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'ownerUid', 'status', 'dueAt', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy', 'completedAt', 'completedBy', 'sourceMessageId', 'sourceMessageTextPreview'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 1000))
                      && request.resource.data.ownerUid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
                      && request.resource.data.status in ['pending', 'done', 'cancelled'];
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'ownerUid', 'status', 'dueAt', 'createdBy', 'createdAt', 'updatedAt', 'updatedBy', 'completedAt', 'completedBy', 'sourceMessageId', 'sourceMessageTextPreview'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 1000))
                      && request.resource.data.ownerUid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
                      && request.resource.data.status in ['pending', 'done', 'cancelled'];
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Misunderstandings subcollection (Clear the Air)
      match /misunderstandings/{markerId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['whatIMeant', 'whatIHeard', 'whatINeed', 'status', 'responseByOther', 'createdBy', 'createdAt', 'updatedAt', 'resolvedBy', 'resolvedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.status in ['open', 'resolved']
                      && (!('whatIMeant' in request.resource.data) || (request.resource.data.whatIMeant is string && request.resource.data.whatIMeant.size() <= 1000))
                      && (!('whatIHeard' in request.resource.data) || (request.resource.data.whatIHeard is string && request.resource.data.whatIHeard.size() <= 1000))
                      && (!('whatINeed' in request.resource.data) || (request.resource.data.whatINeed is string && request.resource.data.whatINeed.size() <= 1000));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['whatIMeant', 'whatIHeard', 'whatINeed', 'status', 'responseByOther', 'createdBy', 'createdAt', 'updatedAt', 'resolvedBy', 'resolvedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.status in ['open', 'resolved']
                      && (!('whatIMeant' in request.resource.data) || (request.resource.data.whatIMeant is string && request.resource.data.whatIMeant.size() <= 1000))
                      && (!('whatIHeard' in request.resource.data) || (request.resource.data.whatIHeard is string && request.resource.data.whatIHeard.size() <= 1000))
                      && (!('whatINeed' in request.resource.data) || (request.resource.data.whatINeed is string && request.resource.data.whatINeed.size() <= 1000))
                      && (!('responseByOther' in request.resource.data) || (request.resource.data.responseByOther is string && request.resource.data.responseByOther.size() <= 1000));
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Context Capsules subcollection
      match /capsules/{capsuleId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'color', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 100
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 500));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'description', 'color', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.updatedBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 100
                      && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 500));
        allow delete: if isAuthenticated() && isChatMember(chatId);

        // Capsule links subcollection
        match /links/{linkId} {
          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && request.resource.data.keys().hasOnly(['targetType', 'targetId', 'textPreview', 'createdBy', 'createdAt'])
                        && request.resource.data.createdBy == request.auth.uid
                        && request.resource.data.targetType in ['message', 'file', 'reminder', 'note', 'decision', 'event', 'memory', 'vaultItem']
                        && request.resource.data.targetId is string
                        && request.resource.data.textPreview is string
                        && request.resource.data.textPreview.size() <= 200;
          allow delete: if isAuthenticated() && isChatMember(chatId);
        }
      }

      // Gentle follow-ups subcollection
      match /followUps/{followUpId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'relatedType', 'relatedId', 'messageText', 'dueAt', 'assignedTo', 'status', 'sentAt', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.messageText is string
                      && request.resource.data.messageText.size() <= 500
                      && request.resource.data.status in ['pending', 'sent', 'dismissed', 'cancelled']
                      && request.resource.data.relatedType in ['promise', 'reminder', 'message', 'decision', 'other'];
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'relatedType', 'relatedId', 'messageText', 'dueAt', 'assignedTo', 'status', 'sentAt', 'createdBy', 'createdAt', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.messageText is string
                      && request.resource.data.messageText.size() <= 500
                      && request.resource.data.status in ['pending', 'sent', 'dismissed', 'cancelled'];
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // Per-user media state (delete for me - images and videos)
      // Only the owner can access their own media state
      match /userMediaState/{uid}/items/{itemId} {
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && request.resource.data.keys().hasOnly(['messageId', 'mediaKind', 'action', 'createdAt', 'updatedAt', 'createdBy'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.messageId is string
                      && request.resource.data.mediaKind in ['image', 'video', 'link', 'document', 'voice', 'text']
                      && request.resource.data.action == 'deleted_for_me';
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && request.resource.data.keys().hasOnly(['messageId', 'mediaKind', 'action', 'createdAt', 'updatedAt', 'createdBy'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.messageId == resource.data.messageId
                      && request.resource.data.mediaKind in ['image', 'video', 'link', 'document', 'voice', 'text']
                      && request.resource.data.action == 'deleted_for_me';
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Vault items subcollection
      match /vaultItems/{itemId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'category', 'body', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.category in ['emergency', 'health', 'home', 'travel', 'school', 'finance', 'other']
                      && (!('body' in request.resource.data) || (request.resource.data.body is string && request.resource.data.body.size() <= 10000));
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.keys().hasOnly(['title', 'category', 'body', 'createdBy', 'createdAt', 'updatedBy', 'updatedAt'])
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.updatedBy == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() > 0
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.category in ['emergency', 'health', 'home', 'travel', 'school', 'finance', 'other']
                      && (!('body' in request.resource.data) || (request.resource.data.body is string && request.resource.data.body.size() <= 10000));
        allow delete: if isAuthenticated() && isChatMember(chatId);
      }

      // AI Suggestions subcollection - server creates/deletes, client can only read and update status
      match /aiSuggestions/{suggestionId} {
        allow read: if isAuthenticated() && isChatMember(chatId);
        allow create, delete: if false;
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && request.resource.data.type == resource.data.type
                      && request.resource.data.sourceMessageId == resource.data.sourceMessageId
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.createdAt == resource.data.createdAt
                      && request.resource.data.status in ['pending', 'accepted', 'dismissed', 'expired']
                      && request.resource.data.suggestion == resource.data.suggestion;
      }

      // AI Runs subcollection - audit log, no client access
      match /aiRuns/{runId} {
        allow read, write: if false;
      }

      // Private thought read state - only owner can access
      match /thoughtReadState/{uid}/items/{thoughtId} {
        // Helper: Validate read state fields
        function hasOnlyAllowedReadStateFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'readerId', 'lastReadBlockIndex', 'readBlockIds', 'readPercent', 'firstOpenedAt', 'lastReadAt', 'updatedAt']);
        }

        // Only the owner can read their own read state
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        // Only the owner can create/update their own read state
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReadStateFields()
                      && request.resource.data.readerId == request.auth.uid
                      && request.resource.data.thoughtId is string
                      && request.resource.data.readBlockIds is list
                      && request.resource.data.readPercent >= 0
                      && request.resource.data.readPercent <= 100;

        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReadStateFields()
                      && request.resource.data.readerId == request.auth.uid
                      && request.resource.data.thoughtId == resource.data.thoughtId
                      && request.resource.data.readBlockIds is list
                      && request.resource.data.readPercent >= 0
                      && request.resource.data.readPercent <= 100;

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Shared read receipt summary - author can see progress, reader can update
      match /thoughtReadReceipts/{thoughtId}/readers/{uid} {
        // Helper: Validate read receipt fields (no detailed block info)
        function hasOnlyAllowedReceiptFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'readerId', 'readPercent', 'firstOpenedAt', 'lastReadAt', 'updatedAt']);
        }

        // Helper: Get the thought to check authorship
        function getThought() {
          return get(/databases/$(database)/documents/chats/$(chatId)/thoughts/$(thoughtId)).data;
        }

        // Reader can read their own summary, OR author can read summaries for their thoughts
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && (uid == request.auth.uid || getThought().authorId == request.auth.uid);

        // Only the reader can create/update their own receipt
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReceiptFields()
                      && request.resource.data.readerId == request.auth.uid
                      && request.resource.data.thoughtId == thoughtId
                      && request.resource.data.readPercent >= 0
                      && request.resource.data.readPercent <= 100;

        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReceiptFields()
                      && request.resource.data.readerId == request.auth.uid
                      && request.resource.data.thoughtId == resource.data.thoughtId
                      && request.resource.data.readPercent >= 0
                      && request.resource.data.readPercent <= 100;

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Thoughts subcollection - longer personal reflections
      match /thoughts/{thoughtId} {
        // Helper: Validate thought has only allowed fields
        function hasOnlyAllowedThoughtFields() {
          return request.resource.data.keys().hasOnly(['chatId', 'authorId', 'title', 'body', 'blocks', 'mood', 'status', 'createdAt', 'updatedAt', 'removedFromBothAt', 'removedFromBothBy', 'removalRequestId', 'commentsSummary']);
        }

        // Helper: Validate mood value
        function isValidThoughtMood() {
          return request.resource.data.mood in ['normal', 'warm', 'love', 'quiet', 'missing', 'happy', 'hurt', 'romantic', 'confused', 'memory', 'question', 'important'];
        }

        // Helper: Validate status value
        function isValidThoughtStatus() {
          return request.resource.data.status in ['shared', 'deleted', 'removed_from_both'];
        }

        // Helper: Validate blocks array
        function isValidThoughtBlocks() {
          return request.resource.data.blocks is list
              && request.resource.data.blocks.size() <= 100;
        }

        // Helper: Check if user is the author
        function isThoughtAuthor() {
          return resource.data.authorId == request.auth.uid;
        }

        // Helper: Check if update is a removal acceptance (non-author changing to removed_from_both)
        function isValidRemovalAcceptance() {
          return resource.data.authorId != request.auth.uid
              && resource.data.status == 'shared'
              && request.resource.data.status == 'removed_from_both'
              && request.resource.data.removedFromBothBy == request.auth.uid
              && 'removalRequestId' in request.resource.data;
        }

        allow read: if isAuthenticated()
                    && isChatMember(chatId);

        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && hasOnlyAllowedThoughtFields()
                      && request.resource.data.chatId == chatId
                      && request.resource.data.authorId == request.auth.uid
                      && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() <= 120))
                      && request.resource.data.body is string
                      && request.resource.data.body.size() > 0
                      && request.resource.data.body.size() <= 10000
                      && isValidThoughtBlocks()
                      && isValidThoughtMood()
                      && request.resource.data.status == 'shared';

        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && hasOnlyAllowedThoughtFields()
                      && request.resource.data.chatId == resource.data.chatId
                      && request.resource.data.authorId == resource.data.authorId
                      && isValidThoughtMood()
                      && isValidThoughtStatus()
                      && (
                        // Author can edit their own thought
                        (isThoughtAuthor()
                         && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() <= 120))
                         && request.resource.data.body is string
                         && request.resource.data.body.size() > 0
                         && request.resource.data.body.size() <= 10000
                         && isValidThoughtBlocks())
                        // Or non-author can accept removal request
                        || isValidRemovalAcceptance()
                      );

        allow delete: if false;

        // Removal Requests subcollection
        match /removalRequests/{requestId} {
          function hasOnlyAllowedRemovalRequestFields() {
            return request.resource.data.keys().hasOnly(['chatId', 'thoughtId', 'requestedBy', 'requestedAt', 'feeling', 'note', 'status', 'resolvedBy', 'resolvedAt', 'resolution']);
          }

          function isValidRemovalFeeling() {
            return request.resource.data.feeling in ['hurt', 'upset', 'angry', 'overwhelmed', 'need_space', 'prefer_not_to_say'];
          }

          function isValidRemovalStatus() {
            return request.resource.data.status in ['pending', 'accepted', 'dismissed', 'cancelled'];
          }

          function isRemovalRequester() {
            return resource.data.requestedBy == request.auth.uid;
          }

          allow read: if isAuthenticated() && isChatMember(chatId);

          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && hasOnlyAllowedRemovalRequestFields()
                        && request.resource.data.chatId == chatId
                        && request.resource.data.thoughtId == thoughtId
                        && request.resource.data.requestedBy == request.auth.uid
                        && isValidRemovalFeeling()
                        && (!('note' in request.resource.data) || request.resource.data.note == null || (request.resource.data.note is string && request.resource.data.note.size() <= 500))
                        && request.resource.data.status == 'pending';

          allow update: if isAuthenticated()
                        && isChatMember(chatId)
                        && hasOnlyAllowedRemovalRequestFields()
                        && resource.data.status == 'pending'
                        && request.resource.data.chatId == resource.data.chatId
                        && request.resource.data.thoughtId == resource.data.thoughtId
                        && request.resource.data.requestedBy == resource.data.requestedBy
                        && request.resource.data.requestedAt == resource.data.requestedAt
                        && request.resource.data.feeling == resource.data.feeling
                        && request.resource.data.note == resource.data.note
                        && isValidRemovalStatus()
                        && request.resource.data.resolvedBy == request.auth.uid
                        && (
                          // Requester can cancel
                          (isRemovalRequester() && request.resource.data.status == 'cancelled')
                          // Non-requester can accept or dismiss
                          || (!isRemovalRequester() && request.resource.data.status in ['accepted', 'dismissed'])
                        );

          allow delete: if false;
        }

        // Thought Reactions subcollection - doc ID must equal user's uid
        match /reactions/{reactionId} {
          allow read: if isAuthenticated() && isChatMember(chatId);

          allow create, update: if isAuthenticated()
                                && isChatMember(chatId)
                                && reactionId == request.auth.uid
                                && request.resource.data.keys().hasOnly(['uid', 'reaction', 'createdAt', 'updatedAt'])
                                && request.resource.data.uid == request.auth.uid
                                && request.resource.data.reaction in ['heart', 'comfort', 'sad', 'beautiful', 'thanks'];

          allow delete: if isAuthenticated()
                        && isChatMember(chatId)
                        && reactionId == request.auth.uid;
        }

        // Thought Comments subcollection
        match /comments/{commentId} {
          // Helper: Validate comment has only allowed fields
          function hasOnlyAllowedCommentFields() {
            return request.resource.data.keys().hasOnly(['chatId', 'thoughtId', 'authorId', 'text', 'parentCommentId', 'rootCommentId', 'depth', 'path', 'status', 'createdAt', 'updatedAt', 'editedAt']);
          }

          // Helper: Check if user is comment author
          function isCommentAuthor() {
            return resource.data.authorId == request.auth.uid;
          }

          // Helper: Validate comment status
          function isValidCommentStatus() {
            return request.resource.data.status in ['active', 'deleted'];
          }

          allow read: if isAuthenticated() && isChatMember(chatId);

          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && hasOnlyAllowedCommentFields()
                        && request.resource.data.chatId == chatId
                        && request.resource.data.thoughtId == thoughtId
                        && request.resource.data.authorId == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 2000
                        && (request.resource.data.parentCommentId == null || request.resource.data.parentCommentId is string)
                        && (request.resource.data.rootCommentId == null || request.resource.data.rootCommentId is string)
                        && request.resource.data.depth is number
                        && request.resource.data.depth >= 0
                        && request.resource.data.path is list
                        && request.resource.data.status == 'active';

          allow update: if isAuthenticated()
                        && isChatMember(chatId)
                        && isCommentAuthor()
                        && hasOnlyAllowedCommentFields()
                        && request.resource.data.chatId == resource.data.chatId
                        && request.resource.data.thoughtId == resource.data.thoughtId
                        && request.resource.data.authorId == resource.data.authorId
                        && request.resource.data.parentCommentId == resource.data.parentCommentId
                        && request.resource.data.rootCommentId == resource.data.rootCommentId
                        && request.resource.data.depth == resource.data.depth
                        && request.resource.data.path == resource.data.path
                        && request.resource.data.createdAt == resource.data.createdAt
                        && (request.resource.data.text is string && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 2000)
                        && isValidCommentStatus();

          allow delete: if false;

          // Comment Reactions subcollection - doc ID must equal user's uid
          match /reactions/{reactionId} {
            allow read: if isAuthenticated() && isChatMember(chatId);

            allow create, update: if isAuthenticated()
                                  && isChatMember(chatId)
                                  && reactionId == request.auth.uid
                                  && request.resource.data.keys().hasOnly(['uid', 'reaction', 'createdAt', 'updatedAt'])
                                  && request.resource.data.uid == request.auth.uid
                                  && request.resource.data.reaction in ['like', 'dislike'];

            allow delete: if isAuthenticated()
                          && isChatMember(chatId)
                          && reactionId == request.auth.uid;
          }
        }
      }

      // Per-user Thought Comment Read State
      // Path: chats/{chatId}/thoughtCommentReadState/{uid}/items/{thoughtId}
      match /thoughtCommentReadState/{uid}/items/{thoughtId} {
        function hasOnlyAllowedCommentReadStateFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'userId', 'lastSeenCommentsAt', 'lastSeenCommentId', 'unreadCountSnapshot', 'updatedAt']);
        }

        // Only the owner can read their own comment read state
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        // Only the owner can create their own comment read state
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedCommentReadStateFields()
                      && request.resource.data.thoughtId == thoughtId
                      && request.resource.data.userId == request.auth.uid;

        // Only the owner can update their own comment read state
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedCommentReadStateFields()
                      && request.resource.data.thoughtId == thoughtId
                      && request.resource.data.userId == request.auth.uid;

        // Only the owner can delete their own comment read state
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Per-user Thought state (hidden/restored)
      // Path: chats/{chatId}/thoughtUserState/{uid}/items/{thoughtId}
      match /thoughtUserState/{uid}/items/{thoughtId} {
        function hasOnlyAllowedThoughtUserStateFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'userId', 'state', 'source', 'removalRequestId', 'createdAt', 'updatedAt']);
        }

        function isValidThoughtUserState() {
          return request.resource.data.state in ['hidden_due_to_removal_request', 'restored'];
        }

        function isValidThoughtUserStateSource() {
          return request.resource.data.source in ['self_request', 'accepted_removal'];
        }

        // Only the owner can read their own state
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        // Only the owner can write their own state
        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && hasOnlyAllowedThoughtUserStateFields()
                              && request.resource.data.thoughtId == thoughtId
                              && request.resource.data.userId == request.auth.uid
                              && isValidThoughtUserState()
                              && isValidThoughtUserStateSource();

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Per-user Saved Thoughts
      // Path: chats/{chatId}/thoughtUserState/{uid}/saved/{thoughtId}
      match /thoughtUserState/{uid}/saved/{thoughtId} {
        function hasOnlyAllowedSavedFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'userId', 'saved', 'createdAt', 'updatedAt']);
        }

        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && hasOnlyAllowedSavedFields()
                              && request.resource.data.thoughtId == thoughtId
                              && request.resource.data.userId == request.auth.uid
                              && request.resource.data.saved is bool;

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Per-user Archived Thoughts
      // Path: chats/{chatId}/thoughtUserState/{uid}/archived/{thoughtId}
      match /thoughtUserState/{uid}/archived/{thoughtId} {
        function hasOnlyAllowedArchivedFields() {
          return request.resource.data.keys().hasOnly(['thoughtId', 'userId', 'archived', 'createdAt', 'updatedAt']);
        }

        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        allow create, update: if isAuthenticated()
                              && isChatMember(chatId)
                              && uid == request.auth.uid
                              && hasOnlyAllowedArchivedFields()
                              && request.resource.data.thoughtId == thoughtId
                              && request.resource.data.userId == request.auth.uid
                              && request.resource.data.archived is bool;

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Per-user Thought Reminders
      // Path: chats/{chatId}/thoughtReminders/{uid}/items/{reminderId}
      match /thoughtReminders/{uid}/items/{reminderId} {
        function hasOnlyAllowedReminderFields() {
          return request.resource.data.keys().hasOnly(['reminderId', 'thoughtId', 'userId', 'remindAt', 'status', 'note', 'createdAt', 'updatedAt', 'completedAt']);
        }

        function isValidReminderStatus() {
          return request.resource.data.status in ['active', 'completed', 'cancelled'];
        }

        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReminderFields()
                      && request.resource.data.reminderId == reminderId
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.thoughtId is string
                      && request.resource.data.remindAt is timestamp
                      && isValidReminderStatus()
                      && (!('note' in request.resource.data) || request.resource.data.note == null || (request.resource.data.note is string && request.resource.data.note.size() <= 300));

        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedReminderFields()
                      && request.resource.data.reminderId == resource.data.reminderId
                      && request.resource.data.thoughtId == resource.data.thoughtId
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.remindAt is timestamp
                      && isValidReminderStatus()
                      && (!('note' in request.resource.data) || request.resource.data.note == null || (request.resource.data.note is string && request.resource.data.note.size() <= 300));

        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Thought Drafts - private to each user
      // Path: chats/{chatId}/thoughtDrafts/{uid}/items/{draftId}
      match /thoughtDrafts/{uid}/items/{draftId} {
        // Helper: Validate draft has only allowed fields
        function hasOnlyAllowedDraftFields() {
          return request.resource.data.keys().hasOnly(['chatId', 'authorId', 'title', 'body', 'blocks', 'mood', 'createdAt', 'updatedAt']);
        }

        // Helper: Validate mood value for drafts
        function isValidDraftMood() {
          return request.resource.data.mood in ['normal', 'warm', 'love', 'quiet', 'missing', 'happy', 'hurt', 'romantic', 'confused', 'memory', 'question', 'important'];
        }

        // Helper: Validate blocks array for drafts
        function isValidDraftBlocks() {
          return !('blocks' in request.resource.data)
              || (request.resource.data.blocks is list && request.resource.data.blocks.size() <= 100);
        }

        // Only the owner can read their own drafts
        allow read: if isAuthenticated()
                    && isChatMember(chatId)
                    && uid == request.auth.uid;

        // Only the owner can create their own drafts
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedDraftFields()
                      && request.resource.data.chatId == chatId
                      && request.resource.data.authorId == request.auth.uid
                      && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() <= 120))
                      && (!('body' in request.resource.data) || (request.resource.data.body is string && request.resource.data.body.size() <= 10000))
                      && isValidDraftBlocks()
                      && isValidDraftMood();

        // Only the owner can update their own drafts
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid
                      && hasOnlyAllowedDraftFields()
                      && request.resource.data.chatId == resource.data.chatId
                      && request.resource.data.authorId == resource.data.authorId
                      && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() <= 120))
                      && (!('body' in request.resource.data) || (request.resource.data.body is string && request.resource.data.body.size() <= 10000))
                      && isValidDraftBlocks()
                      && isValidDraftMood();

        // Only the owner can delete their own drafts
        allow delete: if isAuthenticated()
                      && isChatMember(chatId)
                      && uid == request.auth.uid;
      }

      // Video Calls subcollection
      match /calls/{callId} {
        // Helper: Get chat members
        function getChatMembers() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        }

        // Helper: Check if receiverId is the other chat member
        function isValidReceiver(receiverId) {
          let members = getChatMembers();
          return receiverId in members && receiverId != request.auth.uid;
        }

        // Helper: Validate call has only allowed fields
        function hasOnlyAllowedCallFields() {
          return request.resource.data.keys().hasOnly([
            'chatId', 'createdBy', 'receiverId', 'status', 'type',
            'createdAt', 'updatedAt', 'answeredAt', 'endedAt', 'endedBy',
            'offer', 'answer'
          ]);
        }

        // Helper: Validate call status
        function isValidCallStatus() {
          return request.resource.data.status in ['ringing', 'accepted', 'rejected', 'ended', 'missed', 'failed'];
        }

        // Read: Only chat members can read calls
        allow read: if isAuthenticated() && isChatMember(chatId);

        // Create: Only chat members can create calls
        allow create: if isAuthenticated()
                      && isChatMember(chatId)
                      && hasOnlyAllowedCallFields()
                      && request.resource.data.chatId == chatId
                      && request.resource.data.createdBy == request.auth.uid
                      && isValidReceiver(request.resource.data.receiverId)
                      && request.resource.data.status == 'ringing'
                      && request.resource.data.type in ['video', 'voice'];

        // Update: Only chat members can update calls (status changes, offer/answer)
        allow update: if isAuthenticated()
                      && isChatMember(chatId)
                      && hasOnlyAllowedCallFields()
                      && request.resource.data.chatId == resource.data.chatId
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.receiverId == resource.data.receiverId
                      && request.resource.data.type == resource.data.type
                      && isValidCallStatus();

        // Delete: Not allowed (calls are just status-updated to ended)
        allow delete: if false;

        // Caller ICE candidates subcollection
        match /callerCandidates/{candidateId} {
          function hasOnlyAllowedCandidateFields() {
            return request.resource.data.keys().hasOnly([
              'candidate', 'sdpMid', 'sdpMLineIndex', 'usernameFragment', 'createdAt', 'createdBy'
            ]);
          }

          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && hasOnlyAllowedCandidateFields()
                        && request.resource.data.createdBy == request.auth.uid
                        && request.resource.data.candidate is string
                        && (request.resource.data.sdpMid == null || request.resource.data.sdpMid is string)
                        && (request.resource.data.sdpMLineIndex == null || request.resource.data.sdpMLineIndex is number);
          allow update, delete: if false;
        }

        // Receiver ICE candidates subcollection
        match /receiverCandidates/{candidateId} {
          function hasOnlyAllowedCandidateFields() {
            return request.resource.data.keys().hasOnly([
              'candidate', 'sdpMid', 'sdpMLineIndex', 'usernameFragment', 'createdAt', 'createdBy'
            ]);
          }

          allow read: if isAuthenticated() && isChatMember(chatId);
          allow create: if isAuthenticated()
                        && isChatMember(chatId)
                        && hasOnlyAllowedCandidateFields()
                        && request.resource.data.createdBy == request.auth.uid
                        && request.resource.data.candidate is string
                        && (request.resource.data.sdpMid == null || request.resource.data.sdpMid is string)
                        && (request.resource.data.sdpMLineIndex == null || request.resource.data.sdpMLineIndex is number);
          allow update, delete: if false;
        }
      }
    }

    // Invites - read-only for authenticated users, writes managed by Cloud Functions
    match /invites/{inviteCode} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // User documents - users can only access their own data
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // FCM tokens subcollection
      match /fcmTokens/{tokenId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Devices subcollection
      match /devices/{deviceId} {
        allow read, delete: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated()
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll(['label', 'platform', 'createdAt', 'lastSeenAt'])
                      && request.resource.data.label is string
                      && request.resource.data.label.size() <= 100
                      && request.resource.data.platform is string;
        allow update: if isAuthenticated()
                      && request.auth.uid == userId
                      && request.resource.data.label is string
                      && request.resource.data.label.size() <= 100;
      }

      // AI settings - single document per user
      match /settings/ai {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated()
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasOnly(['enabled', 'consentedAt', 'features', 'updatedAt'])
                      && request.resource.data.enabled is bool
                      && (!('features' in request.resource.data) || request.resource.data.features is map);
        allow update: if isAuthenticated()
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasOnly(['enabled', 'consentedAt', 'features', 'updatedAt'])
                      && request.resource.data.enabled is bool
                      && (!('features' in request.resource.data) || request.resource.data.features is map);
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }

      // AI usage - rate limit tracking, read-only for client (server writes)
      match /aiUsage/{windowId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Account deletion requests - users can only create/read their own
    match /accountDeletionRequests/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['uid', 'requestedAt', 'status']);
      allow update, delete: if false;
    }

    // Standalone Thoughts collection (for Thoughts app)
    match /thoughts/{thoughtId} {
      // Helper: Check if user owns or is shared with
      function canAccessThought() {
        let data = resource.data;
        return request.auth.uid == data.userId || request.auth.uid in data.sharedWith;
      }

      // Helper: Check if user can access for create
      function canAccessNewThought() {
        let data = request.resource.data;
        return request.auth.uid == data.userId;
      }

      // Helper: Validate thought fields
      function hasValidThoughtFields() {
        let data = request.resource.data;
        return data.keys().hasOnly(['userId', 'title', 'body', 'preview', 'status', 'sharedWith', 'readBy', 'createdAt', 'sentAt'])
            && data.title is string
            && data.title.size() <= 200
            && data.body is string
            && data.body.size() <= 10000
            && data.preview is string
            && data.preview.size() <= 150
            && data.status in ['draft', 'shared']
            && data.sharedWith is list;
      }

      // Read: Owner or shared with
      allow read: if isAuthenticated() && canAccessThought();

      // Create: Only owner
      allow create: if isAuthenticated()
                    && canAccessNewThought()
                    && hasValidThoughtFields();

      // Update: Owner can edit, shared users can mark as read
      allow update: if isAuthenticated()
                    && canAccessThought()
                    && (
                      // Owner can update anything
                      request.auth.uid == resource.data.userId
                      // Shared user can only update readBy field
                      || (request.auth.uid in resource.data.sharedWith
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
                    );

      // Delete: Only owner
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
