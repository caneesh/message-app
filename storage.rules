rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // BACKUP FILES - No client access allowed
    // Backups are created and managed by Admin SDK only
    match /backups/{allPaths=**} {
      allow read, write: if false;
    }

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if content type is an image
    function isImageContentType() {
      return request.resource.contentType.matches('image/.*');
    }

    // Helper: Check if content type is a video
    function isVideoContentType() {
      return request.resource.contentType.matches('video/.*');
    }

    // Helper: Allowed document content types
    function isDocumentContentType() {
      return request.resource.contentType in [
        'application/pdf',
        'text/plain'
      ];
    }

    // Helper: Combined file types (images, videos, documents)
    function isAllowedFileContentType() {
      return isImageContentType() || isVideoContentType() || isDocumentContentType();
    }

    // Helper: Allowed voice content types
    function isAllowedVoiceContentType() {
      return request.resource.contentType in [
        'audio/webm',
        'audio/mp4',
        'audio/mpeg',
        'audio/aac',
        'audio/x-m4a',
        'audio/mp4a-latm'
      ];
    }

    // Helper: File size limit (5 MB for images/docs, 100 MB for videos)
    function isWithinSizeLimit() {
      return request.resource.size <= 25 * 1024 * 1024;
    }

    function isWithinVideoSizeLimit() {
      return request.resource.size <= 100 * 1024 * 1024;
    }

    // Chat files path: chatFiles/{chatId}/{messageId}/{fileName}
    match /chatFiles/{chatId}/{messageId}/{fileName} {
      // Read: any authenticated user (Firestore rules protect message access)
      allow read: if isAuthenticated();

      // Write: authenticated users with valid file type and size
      allow write: if isAuthenticated()
                   && (((isImageContentType() || isDocumentContentType()) && isWithinSizeLimit())
                       || (isVideoContentType() && isWithinVideoSizeLimit()));

      // Delete: any authenticated user
      allow delete: if isAuthenticated();
    }

    // Chat voice notes path: chatVoice/{chatId}/{messageId}/{fileName}
    match /chatVoice/{chatId}/{messageId}/{fileName} {
      // Read: any authenticated user (Firestore rules protect message access)
      allow read: if isAuthenticated();

      // Write: authenticated users with valid audio type and size
      allow write: if isAuthenticated()
                   && isAllowedVoiceContentType()
                   && isWithinSizeLimit();

      // Delete: any authenticated user
      allow delete: if isAuthenticated();
    }

    // Chat attachment bundles path: chatAttachments/{chatId}/{messageId}/{attachmentId}/{fileName}
    match /chatAttachments/{chatId}/{messageId}/{attachmentId}/{fileName} {
      // Read: any authenticated user (Firestore rules protect message access)
      allow read: if isAuthenticated();

      // Write: authenticated users with valid file type and size
      allow write: if isAuthenticated()
                   && (((isImageContentType() || isDocumentContentType()) && isWithinSizeLimit())
                       || (isVideoContentType() && isWithinVideoSizeLimit())
                       || (isAllowedVoiceContentType() && isWithinSizeLimit()));

      // Delete: any authenticated user
      allow delete: if isAuthenticated();
    }
  }
}
