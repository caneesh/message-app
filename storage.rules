rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Allowed file content types
    function isAllowedFileContentType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp',
        'image/heic',
        'image/heif',
        'image/avif',
        'application/pdf',
        'text/plain'
      ];
    }

    // Helper: Allowed voice content types
    function isAllowedVoiceContentType() {
      return request.resource.contentType in [
        'audio/webm',
        'audio/mp4',
        'audio/mpeg',
        'audio/aac'
      ];
    }

    // Helper: File size limit (5 MB)
    function isWithinSizeLimit() {
      return request.resource.size <= 5 * 1024 * 1024;
    }

    // Chat files path: chatFiles/{chatId}/{messageId}/{fileName}
    match /chatFiles/{chatId}/{messageId}/{fileName} {
      // Read: any authenticated user (Firestore rules protect message access)
      allow read: if isAuthenticated();

      // Write: authenticated users with valid file type and size
      allow write: if isAuthenticated()
                   && isAllowedFileContentType()
                   && isWithinSizeLimit();

      // Delete: any authenticated user
      allow delete: if isAuthenticated();
    }

    // Chat voice notes path: chatVoice/{chatId}/{messageId}/{fileName}
    match /chatVoice/{chatId}/{messageId}/{fileName} {
      // Read: any authenticated user (Firestore rules protect message access)
      allow read: if isAuthenticated();

      // Write: authenticated users with valid audio type and size
      allow write: if isAuthenticated()
                   && isAllowedVoiceContentType()
                   && isWithinSizeLimit();

      // Delete: any authenticated user
      allow delete: if isAuthenticated();
    }
  }
}
